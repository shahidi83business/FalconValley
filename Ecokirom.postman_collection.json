              "raw": "{{base_url}}/scenarios?category_id={{category_id}}&q=&limit=50&skip=0",
              "host": ["{{base_url}}"],
              "path": ["scenarios"],
              "query": [
                { "key": "category_id", "value": "{{category_id}}", "disabled": true },
                { "key": "q", "value": "", "disabled": true },
                { "key": "limit", "value": "50" },
                { "key": "skip", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get Random Scenario",
          "request": {
            "method": "GET",
