    {
      "name": "Scenarios",
      "item": [
        {
          "name": "Create Scenario",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"A factory can upgrade filters or keep old equipment. What should it do?\",\n  \"options\": [\"Upgrade filters\", \"Keep old equipment\"],\n  \"correct_option\": 0,\n  \"category_id\": \"{{category_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/scenarios",
              "host": ["{{base_url}}"],
              "path": ["scenarios"]
            }
          }
        },
        {
          "name": "List Scenarios",
          "request": {
            "method": "GET",
            "header": [],
