              "raw": "{{base_url}}/scenarios/random?category_id={{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["scenarios", "random"],
              "query": [
                { "key": "category_id", "value": "{{category_id}}", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Scenario",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/scenarios/{{scenario_id}}",
              "host": ["{{base_url}}"],
