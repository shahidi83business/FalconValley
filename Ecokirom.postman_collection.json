            }
          }
        },
        {
          "name": "Update Scenario",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Updated scenario text\",\n  \"options\": [\"Option A\", \"Option B\"],\n  \"correct_option\": 0,\n  \"category_id\": \"{{category_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/scenarios/{{scenario_id}}",
              "host": ["{{base_url}}"],
              "path": ["scenarios", "{{scenario_id}}"]
            }
          }
        },
        {
          "name": "Delete Scenario",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/scenarios/{{scenario_id}}",
              "host": ["{{base_url}}"],
              "path": ["scenarios", "{{scenario_id}}"]
            }
          }
        },
        {
          "name": "Get Scenarios By Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/categories/{{category_id}}/scenarios",
              "host": ["{{base_url}}"],
              "path": ["categories", "{{category_id}}", "scenarios"]
            }
          }
        },
        {
          "name": "Validate Answer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"selected_option\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/scenarios/{{scenario_id}}/validate-answer",
              "host": ["{{base_url}}"],
              "path": ["scenarios", "{{scenario_id}}", "validate-answer"]
            }
          }
        }
      ]
    },
